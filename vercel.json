{
  "version": 2,
  "routes": [
    {
      "src": "/api(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/frontend/admin/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/assets/$1"
    },
    {
      "src": "/components/(.*)",
      "dest": "/frontend/components/$1"
    },
    {
      "src": "/syarat-ketentuan(\\.html)?",
      "dest": "/frontend/syarat-ketentuan.html"
    },
    {
      "src": "/kebijakan-privasi(\\.html)?",
      "dest": "/frontend/kebijakan-privasi.html"
    },
    {
      "src": "/kebijakan-refund(\\.html)?",
      "dest": "/frontend/kebijakan-refund.html"
    },
    {
      "src": "/kebijakan-pengiriman(\\.html)?",
      "dest": "/frontend/kebijakan-pengiriman.html"
    },
    {
      "src": "/kontak(\\.html)?",
      "dest": "/frontend/kontak.html"
    },
    {
      "src": "/",
      "dest": "/frontend/index.html"
    }
  ]
}
